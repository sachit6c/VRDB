# Used by scripts/db-migrate.mjs. Copy to .env and fill in.
# SUPABASE_URL is the same as in vrdb-config.js.
# SUPABASE_DB_PASSWORD: Supabase dashboard → Project Settings → Database → Database password.
# SUPABASE_POOLER_HOST: defaults to aws-1-us-west-2.pooler.supabase.com — override if your project is in a different region.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_DB_PASSWORD=your-db-password
# SUPABASE_POOLER_HOST=aws-1-us-west-2.pooler.supabase.com
